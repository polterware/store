{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ops",
  "version": "0.1.0",
  "identifier": "com.polterware.ops",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "transparent": true,
        "title": "",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxRUQwMjFFQjMyNzg0OUUKUldTZWhDZXpIZ0x0c1NQMVBuTzB2TjVyNHZNdW91MEJXcFV2TlpGOXI2YzVUV0p6QlN3QUR6Q0YK",
      "endpoints": [
        "https://github.com/polterware/ops/releases/latest/download/latest.json"
      ]
    }
  }
}
